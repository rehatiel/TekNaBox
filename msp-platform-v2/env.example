# Copy to .env and fill in secrets before running

# Required secrets - generate strong random values
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
DEVICE_TOKEN_SECRET=CHANGE_ME_different_from_SECRET_KEY
DB_PASSWORD=CHANGE_ME_strong_db_password
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# Environment
ENVIRONMENT=production
LOG_LEVEL=INFO

# Artifact storage (bind-mounted volume path inside container)
ARTIFACT_BUCKET=/artifacts

# UI Build
# Public URL of the API server — baked into the frontend at build time
# Must match the externally accessible URL of your api container
VITE_API_BASE=https://your-api-server.example.com
VITE_WS_BASE=https://tekn-api.synhow.com