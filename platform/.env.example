# =============================================================================
# TekNaBox — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in all values before running docker compose.
# Generate secrets with: python3 -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# ── Bootstrap ─────────────────────────────────────────────────────────────────
# Super admin account created automatically on first startup.
# Ignored if the platform has already been bootstrapped.
BOOTSTRAP_EMAIL=admin@yourdomain.com
BOOTSTRAP_PASSWORD=ChangeMe123!

# ── Security (REQUIRED) ───────────────────────────────────────────────────────
# Generate two separate secrets — do not reuse between fields.
SECRET_KEY=change_me_generate_with_secrets_token_hex_32
DEVICE_TOKEN_SECRET=change_me_different_from_secret_key

# VITE
VITE_API_BASE=https://api.yourhosting.com
VITE_WS_BASE=https://portal.yourhost.com

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_db_password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_strong_redis_password

# ── Storage ───────────────────────────────────────────────────────────────────
ARTIFACT_BUCKET=/artifacts

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=INFO

# ── Token Expiry ──────────────────────────────────────────────────────────────
# How long operator browser sessions last (minutes)
OPERATOR_TOKEN_EXPIRE_MINUTES=60
# How long device JWTs last before refresh (hours)
DEVICE_TOKEN_EXPIRE_HOURS=168

# ── Device Heartbeat & Monitoring ─────────────────────────────────────────────
# How often Pi agents send heartbeats (seconds) — pushed to agents on connect
DEVICE_HEARTBEAT_INTERVAL=30
# How long without a heartbeat before marking device OFFLINE (seconds)
# Should be at least 2x DEVICE_HEARTBEAT_INTERVAL
DEVICE_HEARTBEAT_TIMEOUT=90
# How often the server checks for dead devices (seconds)
HEARTBEAT_MONITOR_INTERVAL=30

# ── Task Settings ─────────────────────────────────────────────────────────────
# Default task timeout if operator doesn't specify (seconds)
DEFAULT_TASK_TIMEOUT_SECONDS=300
# Extra grace period before marking task as TIMEOUT (seconds)
TASK_TIMEOUT_GRACE_SECONDS=30
# How often the task watchdog runs (seconds)
TASK_WATCHDOG_INTERVAL=30

# ── Agent Reconnect Behaviour ─────────────────────────────────────────────────
# Min/max backoff for agent WebSocket reconnects (seconds)
AGENT_RECONNECT_MIN_SECONDS=5
AGENT_RECONNECT_MAX_SECONDS=300

# ── Update Scheduler ──────────────────────────────────────────────────────────
# How often to re-notify devices of pending updates (seconds)
UPDATE_SCHEDULER_INTERVAL=300

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all
# Example: https://yourserver.com,https://admin.yourserver.com
CORS_ORIGINS=*
